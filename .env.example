# pscale-biome environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# === Storage (one of these — biome senses which) ===

# Upstash Redis (vendored from pscale-beach, default for Vercel-style deploys)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase (vendored from bsp-mcp-server, optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Filesystem path (for thumbdrive / dev biome) — defaults to ./blocks if unset
BIOME_FS_PATH=

# === Cognition (optional — biome runs without LLM; with LLM it grows a hermit-crab) ===

ANTHROPIC_API_KEY=

# === Endpoints / Federation ===

# Bare domain or Vercel project URL — part of lock salt namespace, set ONCE
BEACH_ORIGIN=

# Where this biome considers its public face (full URL with scheme)
BIOME_URL=

# === Operator presence (used by the seed wizard) ===

BEACH_HANDLE=
BEACH_PASSPHRASE=

# === Optional ===

# Subset of library blocks to seed; "all", "none", or comma-separated names
LIBRARY_SUBSET=all

# Port for any HTTP surfaces the biome unfolds
PORT=3001
